  severity:   CRITICAL | IMPORTANT | SUGGESTION
  file, line: location (line >= 1)
  category:   complexity | logic | style
  title:      10-120 chars
  body:       1-3 sentences naming the principle and the concrete smell
  suggested_fix: optional code or guidance
  confidence: 0.0-1.0
