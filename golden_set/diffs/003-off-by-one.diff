+def pairs(items):
+    """Yield (prev, next) tuples for adjacent elements."""
+    return list(zip(items, items[1:]))
+
+
+def deltas(items):
+    """Return consecutive differences between numeric items.
+
+    Used by services.metrics to compute rate-of-change over a sample window.
+    """
+    result = []
+    for i in range(len(items)):
+        result.append(items[i + 1] - items[i])
+    return result
